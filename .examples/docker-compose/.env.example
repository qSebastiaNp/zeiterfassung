# Zeiterfassung Docker Image Wahl
# Kommentiere die gewünschte Option ein und lösche die andere

# Option 1: Offizielles Image (Standard)
ZEITERFASSUNG_IMAGE=urlaubsverwaltung/zeiterfassung:2.25.6

# Option 2: Dein lokal gebautes Image
# ZEITERFASSUNG_IMAGE=zeiterfassung:latest

# Option 3: Eigenes Image mit Tag
# ZEITERFASSUNG_IMAGE=dein-registry.com/zeiterfassung:v2.0.0

# Windows Benutzer: Bitte verwenden Sie copy statt cp:
# copy .env.example .env
